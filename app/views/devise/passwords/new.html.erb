<div class="row justify-content-center">
  <div class="col-lg-5">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h1 class="h4 fw-bold mb-4">Forgot your password?</h1>

        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
          <div class="mb-4">
            <%= f.label :email, class: "form-label fw-semibold" %>
            <%= f.email_field :email, class: "form-control #{'is-invalid' if resource.errors[:email].any?}", required: true, autofocus: true, autocomplete: "email" %>
            <div class="invalid-feedback"><%= resource.errors[:email].first %></div>
          </div>

          <%= f.submit "Send reset instructions", class: "btn btn-primary w-100" %>
        <% end %>

        <div class="mt-3 text-center text-muted small">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
