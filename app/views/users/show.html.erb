<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body p-4">
        <div class="d-flex align-items-center gap-3 mb-4">
          <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold fs-4 user-avatar">
            <%= @user.name[0].upcase %>
          </div>
          <div>
            <h1 class="h4 fw-bold mb-0"><%= @user.name %></h1>
            <p class="text-muted mb-0"><%= @user.email %></p>
          </div>
        </div>

        <div class="mb-3">
          <strong>Roles:</strong>
          <% @user.roles.each do |role| %>
            <span class="badge ms-1 <%= role.name == 'admin' ? 'bg-danger' : role.name == 'organizer' ? 'bg-primary' : 'bg-secondary' %>"><%= role.name.capitalize %></span>
          <% end %>
        </div>

        <% if policy(@user).update_roles? %>
          <%= form_with url: update_roles_user_path(@user), method: :patch, class: "mt-3" do |f| %>
            <strong>Edit Roles:</strong>
            <div class="d-flex gap-3 mt-2" id="edit-roles">
              <% ['attendee', 'organizer', 'admin'].each do |role_name| %>
                <div class="form-check">
                  <%= check_box_tag 'role_names[]', role_name, @user.roles.any? { |r| r.name == role_name }, class: "form-check-input role-checkbox", id: "role_#{role_name}", data: { role: role_name } %>
                  <%= label_tag "role_#{role_name}", role_name.capitalize, class: "form-check-label" %>
                </div>
              <% end %>
            </div>
            <%= f.submit "Update Roles", class: "btn btn-primary btn-sm mt-2", id: "update-roles-btn" %>
          <% end %>
        <% end %>

        <% if policy(@user).destroy? %>
          <%= button_to user_path(@user), method: :delete, class: "btn btn-outline-danger btn-sm", data: { confirm: "Delete #{@user.name}?" } do %>
            <i class="bi bi-trash me-1"></i> Delete User
          <% end %>
        <% end %>
      </div>
    </div>

    <h2 class="h5 fw-bold mb-3">Registered Events</h2>
    <% if @user.registered_events.empty? %>
      <p class="text-muted">No registered events.</p>
    <% else %>
      <div class="d-flex flex-column gap-2">
        <% @user.registered_events.each do |event| %>
          <div class="card border-0 shadow-sm">
            <div class="card-body py-2 px-3">
              <%= link_to event.title, event_path(event), class: "text-decoration-none fw-semibold" %>
              <span class="text-muted small ms-2"><%= event.start_time.strftime("%b %d, %Y") %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= link_to users_path, class: "btn btn-link text-muted mt-3 ps-0" do %>
      <i class="bi bi-arrow-left me-1"></i> Back to Users
    <% end %>
  </div>
</div>
