<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h1 class="h4 fw-bold mb-4">New Event</h1>

        <%= form_with model: @event do |f| %>
          <div class="mb-3">
            <%= f.label :title, class: "form-label fw-semibold" %>
            <%= f.text_field :title, class: "form-control #{'is-invalid' if @event.errors[:title].any?}", required: true %>
            <div class="invalid-feedback"><%= @event.errors[:title].first %></div>
          </div>

          <div class="mb-3">
            <%= f.label :description, class: "form-label fw-semibold" %>
            <%= f.text_area :description, class: "form-control #{'is-invalid' if @event.errors[:description].any?}", rows: 3 %>
            <div class="invalid-feedback"><%= @event.errors[:description].first %></div>
          </div>

          <div class="mb-3">
            <%= f.label :location, class: "form-label fw-semibold" %>
            <%= f.text_field :location, class: "form-control #{'is-invalid' if @event.errors[:location].any?}", required: true %>
            <div class="invalid-feedback"><%= @event.errors[:location].first %></div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <%= f.label :start_time, class: "form-label fw-semibold" %>
              <%= f.datetime_local_field :start_time, class: "form-control #{'is-invalid' if @event.errors[:start_time].any?}", required: true, id: "event_start_time" %>
              <div class="invalid-feedback"><%= @event.errors[:start_time].first %></div>
            </div>
            <div class="col-md-6 mb-3">
              <%= f.label :end_time, class: "form-label fw-semibold" %>
              <%= f.datetime_local_field :end_time, class: "form-control #{'is-invalid' if @event.errors[:end_time].any?}", required: true, id: "event_end_time" %>
              <div class="invalid-feedback"><%= @event.errors[:end_time].first.presence || "Must be after start time" %></div>
            </div>
          </div>

          <div class="mb-4">
            <%= f.label :capacity, class: "form-label fw-semibold" %>
            <%= f.number_field :capacity, class: "form-control #{'is-invalid' if @event.errors[:capacity].any?}", min: 1, required: true %>
            <div class="invalid-feedback"><%= @event.errors[:capacity].first %></div>
          </div>

          <%= f.submit "Create Event", class: "btn btn-primary w-100" %>
        <% end %>
      </div>
    </div>
    <%= link_to events_path, class: "btn btn-link text-muted mt-3 ps-0" do %>
      <i class="bi bi-arrow-left me-1"></i> Back to Events
    <% end %>
  </div>
</div>
