<h1 class="h3 fw-bold mb-4"><i class="bi bi-speedometer2 me-2"></i>System Dashboard</h1>

<div class="row g-4 mb-5">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm bg-primary text-white">
      <div class="card-body d-flex align-items-center gap-3">
        <i class="bi bi-person-check fs-1 opacity-75"></i>
        <div>
          <div class="fs-2 fw-bold"><%= @registrations.count %></div>
          <div class="opacity-75">Total Registrations</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm bg-warning text-dark">
      <div class="card-body d-flex align-items-center gap-3">
        <i class="bi bi-hourglass-split fs-1 opacity-75"></i>
        <div>
          <div class="fs-2 fw-bold"><%= @waitlist_entries.count %></div>
          <div class="opacity-75">Waitlist Entries</div>
        </div>
      </div>
    </div>
  </div>
</div>

<h2 class="h5 fw-bold mb-3">All Registrations</h2>
<div class="card border-0 shadow-sm mb-5">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>User</th>
          <th>Event</th>
          <th>Status</th>
          <th>Registered At</th>
        </tr>
      </thead>
      <tbody>
        <% @registrations.each do |r| %>
          <tr>
            <td><%= r.user.name %></td>
            <td><%= link_to r.event.title, event_path(r.event), class: "text-decoration-none" %></td>
            <td><span class="badge <%= r.confirmed? ? 'bg-success' : 'bg-secondary' %>"><%= r.status %></span></td>
            <td class="text-muted small"><%= r.created_at.strftime("%b %d, %Y %H:%M") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<h2 class="h5 fw-bold mb-3">All Registrations</h2>
<div class="card border-0 shadow-sm mb-3">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>User</th>
          <th>Event</th>
          <th>Status</th>
          <th>Registered At</th>
        </tr>
      </thead>
      <tbody>
        <% @registrations.each do |r| %>
          <tr>
            <td><%= r.user.name %></td>
            <td><%= link_to r.event.title, event_path(r.event), class: "text-decoration-none" %></td>
            <td><span class="badge <%= r.confirmed? ? 'bg-success' : 'bg-secondary' %>"><%= r.status %></span></td>
            <td class="text-muted small"><%= r.created_at.strftime("%b %d, %Y %H:%M") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<div class="mb-5 d-flex justify-content-center">
  <%= paginate @registrations %>
</div>

<h2 class="h5 fw-bold mb-3">All Waitlist Entries</h2>
<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>Position</th>
          <th>User</th>
          <th>Event</th>
        </tr>
      </thead>
      <tbody>
        <% @waitlist_entries.each do |w| %>
          <tr>
            <td><span class="badge bg-warning text-dark">#<%= w.position %></span></td>
            <td><%= w.user.name %></td>
            <td><%= link_to w.event.title, event_path(w.event), class: "text-decoration-none" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<div class="mt-3 d-flex justify-content-center">
  <%= paginate @waitlist_entries %>
</div>
