<!DOCTYPE html>
<html>
  <body style="font-family: Arial, sans-serif; background-color: #f4f4f4; margin: 0; padding: 0;">
    <div style="max-width: 600px; margin: 40px auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">

      <div style="background-color: #4f46e5; padding: 32px; text-align: center;">
        <h1 style="color: #ffffff; margin: 0; font-size: 24px;">Event System</h1>
      </div>

      <div style="padding: 32px;">
        <p style="color: #374151; font-size: 16px;">Hi <strong><%= @user.name %></strong>,</p>

        <div style="background-color: #f9fafb; border-left: 4px solid #4f46e5; padding: 16px 20px; margin: 24px 0; border-radius: 4px;">
          <h2 style="color: #1f2937; margin: 0 0 8px 0; font-size: 18px;"><%= @title %></h2>
          <p style="color: #6b7280; margin: 0; font-size: 15px;"><%= @body %></p>
        </div>

        <p style="color: #9ca3af; font-size: 13px; margin-top: 32px;">
          You are receiving this email because you have an account on Event System.
        </p>
      </div>

      <div style="background-color: #f9fafb; padding: 16px; text-align: center; border-top: 1px solid #e5e7eb;">
        <p style="color: #9ca3af; font-size: 12px; margin: 0;">© 2026 Event System. All rights reserved.</p>
      </div>

    </div>
  </body>
</html>
