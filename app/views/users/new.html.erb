<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h1 class="h4 fw-bold mb-4"><i class="bi bi-person-plus me-2"></i>Create New User</h1>

        <%= form_with model: @user, url: admin_create_users_path do |f| %>
          <% if @user.errors[:base].any? %>
            <div class="alert alert-danger"><%= @user.errors[:base].first %></div>
          <% end %>
          <div class="mb-3">
            <%= f.label :name, class: "form-label fw-semibold" %>
            <%= f.text_field :name, class: "form-control #{'is-invalid' if @user.errors[:name].any?}", required: true %>
            <div class="invalid-feedback"><%= @user.errors[:name].first %></div>
          </div>

          <div class="mb-3">
            <%= f.label :email, class: "form-label fw-semibold" %>
            <%= f.email_field :email, class: "form-control #{'is-invalid' if @user.errors[:email].any?}", required: true %>
            <div class="invalid-feedback"><%= @user.errors[:email].first %></div>
          </div>

          <div class="mb-4">
            <%= label_tag :roles, "Roles", class: "form-label fw-semibold d-block" %>
            <% [["Attendee", "attendee"], ["Organizer", "organizer"], ["Admin", "admin"]].each do |label, value| %>
              <div class="form-check">
                <%= check_box_tag "user[roles][]", value, false, class: "form-check-input role-checkbox", id: "role_#{value}", data: { role: value } %>
                <%= label_tag "role_#{value}", label, class: "form-check-label" %>
              </div>
            <% end %>
          </div>

          <%= f.submit "Create User", class: "btn btn-primary w-100" %>
        <% end %>
      </div>
    </div>

    <%= link_to users_path, class: "btn btn-link text-muted mt-3 ps-0" do %>
      <i class="bi bi-arrow-left me-1"></i> Back to Users
    <% end %>
  </div>
</div>
